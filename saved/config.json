{
    "name": "MolPot Config Example",
    "n_gpu": 0,
    "model": {
        "type": "PiNet",
        "args": {}
    },
    "data_loader": {
        "type": "QM9",
        "args": {
            "data_dir": "data/",
            "batch_size": 128,
            "pipelines": {
                "shuffle": {}
            },
            "num_workers": 2,
            "random_split": {
                "total_length": 10,
                "weights": {
                    "train": 0.8,
                    "valid": 0.2
                },
                "seed": 0
            }
        }
    },
    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.001,
            "weight_decay": 0,
            "amsgrad": true
        }
    },
    "loss": "nll_loss",
    "metrics": [
        "accuracy",
        "top_k_acc"
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 50,
            "gamma": 0.1
        }
    },
    "trainer": {
        "epochs": 100,
        "save_dir": "saved/",
        "save_period": 1,
        "verbosity": 2,
        "monitor": "min val_loss",
        "early_stop": 10
    }
}