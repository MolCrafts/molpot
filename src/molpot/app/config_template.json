{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "n_gpu": {
        "type": "integer"
      },
      "arch": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "args": {
            "type": "object"
          }
        },
        "required": [
          "type",
          "args"
        ]
      },
      "data_loader": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "args": {
            "type": "object",
            "properties": {
              "data_dir": {
                "type": "string"
              },
              "batch_size": {
                "type": "integer"
              },
              "shuffle": {
                "type": "boolean"
              },
              "validation_split": {
                "type": "number"
              },
              "num_workers": {
                "type": "integer"
              }
            },
            "required": [
              "data_dir",
              "batch_size",
              "shuffle",
              "validation_split",
              "num_workers"
            ]
          }
        },
        "required": [
          "type",
          "args"
        ]
      },
      "optimizer": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "args": {
            "type": "object",
            "properties": {
              "lr": {
                "type": "number"
              },
              "weight_decay": {
                "type": "integer"
              },
              "amsgrad": {
                "type": "boolean"
              }
            },
            "required": [
              "lr",
              "weight_decay",
              "amsgrad"
            ]
          }
        },
        "required": [
          "type",
          "args"
        ]
      },
      "loss": {
        "type": "string"
      },
      "metrics": {
        "type": "array",
        "items": {}
      },
      "lr_scheduler": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "args": {
            "type": "object",
            "properties": {
              "step_size": {
                "type": "integer"
              },
              "gamma": {
                "type": "number"
              }
            },
            "required": [
              "step_size",
              "gamma"
            ]
          }
        },
        "required": [
          "type",
          "args"
        ]
      },
      "trainer": {
        "type": "object",
        "properties": {
          "epochs": {
            "type": "integer"
          },
          "save_dir": {
            "type": "string"
          },
          "save_period": {
            "type": "integer"
          },
          "verbosity": {
            "type": "integer"
          },
          "monitor": {
            "type": "string"
          },
          "early_stop": {
            "type": "integer"
          },
          "tensorboard": {
            "type": "boolean"
          }
        },
        "required": [
          "epochs",
          "save_dir",
          "save_period",
          "verbosity",
          "monitor",
          "early_stop",
          "tensorboard"
        ]
      }
    },
    "required": [
      "name",
      "n_gpu",
      "arch",
      "data_loader",
      "optimizer",
      "loss",
      "metrics",
      "lr_scheduler",
      "trainer"
    ]
  }